model_list:
  # ── Base models ───────────────────────────────────────────────────────────
  - model_name: qwen2.5:7b
    litellm_params:
      model: ollama/qwen2.5:7b
      api_base: http://localhost:11434

  - model_name: qwen2.5-coder:14b
    litellm_params:
      model: ollama/qwen2.5-coder:14b
      api_base: http://localhost:11434

  - model_name: deepseek-r1:14b
    litellm_params:
      model: ollama/deepseek-r1:14b
      api_base: http://localhost:11434

  # ── Claude name aliases (for Claude Code compatibility) ───────────────────
  # claude-haiku → qwen2.5:7b (fast, general)
  - model_name: claude-haiku-4-5-20251001
    litellm_params:
      model: ollama/qwen2.5:7b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: false

  - model_name: claude-haiku-4-5-20251001[1m]
    litellm_params:
      model: ollama/qwen2.5:7b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: false

  # claude-sonnet → qwen2.5-coder:14b (strong code + reasoning)
  - model_name: claude-sonnet-4-6
    litellm_params:
      model: ollama/qwen2.5-coder:14b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: false

  - model_name: claude-sonnet-4-6[1m]
    litellm_params:
      model: ollama/qwen2.5-coder:14b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: false

  - model_name: claude-sonnet-4-5
    litellm_params:
      model: ollama/qwen2.5-coder:14b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: false

  # claude-opus → deepseek-r1:14b (reasoning model)
  - model_name: claude-opus-4-6
    litellm_params:
      model: ollama/deepseek-r1:14b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: true

  - model_name: claude-opus-4-6[1m]
    litellm_params:
      model: ollama/deepseek-r1:14b
      api_base: http://localhost:11434
    model_info:
      supports_reasoning: true

  # ── Embeddings ────────────────────────────────────────────────────────────
  - model_name: nomic-embed-text
    litellm_params:
      model: ollama/nomic-embed-text
      api_base: http://localhost:11434

litellm_settings:
  drop_params: true
  request_timeout: 600
  num_retries: 2
  set_verbose: false

general_settings:
  disable_spend_logs: true
