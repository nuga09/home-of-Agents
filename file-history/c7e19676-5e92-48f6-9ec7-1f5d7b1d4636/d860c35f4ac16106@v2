{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=$HOME/.claude/plugins/marketplaces/thedotmack/plugin PATH=$HOME/.local/bin:$PATH node $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/bun-runner.js $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs hook claude-code session-init",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=$HOME/.claude/plugins/marketplaces/thedotmack/plugin PATH=$HOME/.local/bin:$PATH node $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/bun-runner.js $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs hook claude-code observation",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=$HOME/.claude/plugins/marketplaces/thedotmack/plugin PATH=$HOME/.local/bin:$PATH node $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/bun-runner.js $HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs hook claude-code summarize",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true
  },
  "mcpServers": {
    "claude-mem": {
      "type": "stdio",
      "command": "/home/nugad/.claude/plugins/marketplaces/thedotmack/plugin/scripts/mcp-server.cjs"
    }
  },
  "skipDangerousModePermissionPrompt": true
}
