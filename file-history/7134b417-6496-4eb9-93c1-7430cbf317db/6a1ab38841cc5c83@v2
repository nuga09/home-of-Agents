model_list:
  # Fast general-purpose model (~2GB RAM) - good for quick tasks
  - model_name: llama3.2
    litellm_params:
      model: ollama/llama3.2:3b
      api_base: http://localhost:11434

  # Coding-focused model (~3.8GB RAM)
  - model_name: deepseek-coder
    litellm_params:
      model: ollama/deepseek-coder:6.7b
      api_base: http://localhost:11434

  # Reasoning model (~4.7GB RAM)
  - model_name: deepseek-r1
    litellm_params:
      model: ollama/deepseek-r1:7b
      api_base: http://localhost:11434

litellm_settings:
  drop_params: true           # silently ignore unsupported params
  request_timeout: 600        # 10 min — ollama cold-starts can be slow
  num_retries: 2
  set_verbose: false

general_settings:
  # No master_key = no auth required (local use only)
  port: 4000
  host: 127.0.0.1             # localhost only — do not expose externally
  disable_spend_logs: true
